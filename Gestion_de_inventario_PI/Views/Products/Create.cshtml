@model Gestion_de_inventario_PI.Models.Product
@{
    ViewBag.Title = "Nuevo Producto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="details" style="grid-template-columns: 1fr; padding-top: 0;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div>
            <h1 style="font-size: 1.8rem; color: var(--text-primary);">Añadir Producto</h1>
            <p style="color: var(--text-secondary);">Registra un nuevo artículo en el almacén</p>
        </div>
        <a href="@Url.Action("Index")" class="btn-secondary" style="text-decoration: none;">
            <ion-icon name="arrow-back-outline" style="transform: translateY(2px);"></ion-icon> Volver al Inventario
        </a>
    </div>

    @using (Html.BeginForm("Create", "Products", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-card" style="display: block;">
            <div class="form-header">
                <h2>Detalles del Producto</h2>
            </div>

            <div class="form-layout">
                <div class="image-upload-section">
                    <input type="file" name="imagenArchivo" id="imagenArchivo" accept="image/*" style="display: none;" onchange="previewImage(this);" />

                    <div class="image-upload-box" id="uploadBox" onclick="document.getElementById('imagenArchivo').click();" style="cursor: pointer; overflow: hidden; position: relative;">
                        <ion-icon name="camera-outline" id="cameraIcon"></ion-icon>
                        <span id="uploadText">Subir imagen</span>
                        <img id="imagePreview" src="#" alt="Vista previa" style="display: none; width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0;" />
                    </div>
                </div>

                <div class="form-fields">
                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label>Nombre del Producto</label>
                            @Html.TextBoxFor(m => m.name, new { @class = "form-input", placeholder = "Ej: Martillo de Uña", required = "required" })
                            @Html.ValidationMessageFor(m => m.name, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>SKU</label>
                            @Html.TextBoxFor(m => m.code, new { @class = "form-input", placeholder = "HR-001", required = "required" })
                            @Html.ValidationMessageFor(m => m.code, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group">
                            <label>Categoría</label>
                            @Html.DropDownListFor(m => m.categoryId, (SelectList)ViewBag.categoryId, "Seleccione una...", new { @class = "form-input", @required = "required" })
                            @Html.ValidationMessageFor(m => m.categoryId, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Precio Venta ($)</label>
                            @Html.TextBoxFor(m => m.saleprice, new { @class = "form-input", type = "number", step = "0.01", placeholder = "0.00", required = "required", min = 0 })
                            @Html.ValidationMessageFor(m => m.saleprice, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group">
                            <label>Costo ($)</label>
                            @Html.TextBoxFor(m => m.buyingprice, new { @class = "form-input", type = "number", step = "0.01", placeholder = "0.00", required = "required", min = 0 })
                            @Html.ValidationMessageFor(m => m.buyingprice, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group">
                            <label>Stock Inicial</label>
                            @Html.TextBoxFor(m => m.stock, new { @class = "form-input", type = "number", placeholder = "0", required = "required", min = 0 })
                            @Html.ValidationMessageFor(m => m.stock, "", new { @class = "text-danger" })
                        </div>
                    </div>

                </div>
            </div>

            <div class="form-actions" style="margin-top: 20px;">
                <button type="submit" class="btn">
                    <ion-icon name="save-outline" style="margin-right:5px; transform: translateY(2px);"></ion-icon> Guardar Producto
                </button>
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                    document.getElementById('cameraIcon').style.display = 'none';
                    document.getElementById('uploadText').style.display = 'none';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
